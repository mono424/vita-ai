{
  "name": "cv.khadim.io",
  "private": true,
  "scripts": {
    "dev": "spooky dev",
    "dev:app": "pnpm --filter @cv.khadim.io/app dev",
    "build": "spooky generate && pnpm --filter @cv.khadim.io/app build",
    "generate": "spooky generate",
    "migrate:create": "spooky migrate create",
    "migrate:apply": "spooky migrate apply --url http://localhost:8666",
    "migrate:status": "spooky migrate status --url http://localhost:8666"
  },
  "devDependencies": {
    "@spooky-sync/cli": "0.0.1-canary.16"
  },
  "pnpm": {
    "overrides": {
      "@spooky-sync/query-builder": "0.0.1-canary.16",
      "@spooky-sync/core": "0.0.1-canary.16",
      "@spooky-sync/ssp-wasm": "0.0.1-canary.16"
    }
  }
}
