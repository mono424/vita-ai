{
  "name": "cv.khadim.io",
  "private": true,
  "scripts": {
    "dev": "spooky dev",
    "dev:app": "pnpm --filter @cv.khadim.io/app dev",
    "dev:api": "cd packages/render-api && uv run uvicorn render_api.main:app --reload --port 8765",
    "dev:agent": "pnpm --filter @cv.khadim.io/agent-service dev",
    "build": "spooky generate && pnpm --filter @cv.khadim.io/app build",
    "generate": "spooky generate",
    "migrate:create": "spooky migrate create",
    "migrate:apply": "spooky migrate apply --url http://localhost:8666",
    "migrate:status": "spooky migrate status --url http://localhost:8666",
    "cloud:deploy": "npx @spooky-sync/cli@canary cloud deploy",
    "cloud:logs": "npx @spooky-sync/cli@canary cloud logs --split h"
  },
  "devDependencies": {
    "@spooky-sync/cli": "0.0.1-canary.38"
  },
  "pnpm": {
    "overrides": {
      "@spooky-sync/query-builder": "0.0.1-canary.38",
      "@spooky-sync/core": "0.0.1-canary.38",
      "@spooky-sync/ssp-wasm": "0.0.1-canary.38"
    }
  }
}
